APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=true
APP_URL=http://localhost:8082

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=meenitstrac
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Give each Meenits app a DISTINCT session cookie name. Required for local SSO dev:
# on localhost the apps share a host (only the port differs), so a default shared
# cookie name lets MeenitsApp's session clobber MeenitsTrac's mid-OAuth. Harmless in
# prod (app.* and trac.* are separate hosts), but set it everywhere to be safe.
SESSION_COOKIE=meenitstrac_session

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="MeenitsTrac"

# ── "Login with Meenits" — OAuth2 SSO client (MeenitsApp = identity provider) ──
# Create the client in MeenitsApp with:
#   php artisan passport:client --name="MeenitsTrac" \
#     --redirect_uri="https://trac.meenits.app/auth/meenits/callback" --provider=users
# then paste the id/secret here. The *_URL vars default to prod; override for
# local/staging (e.g. point at http://localhost:<meenitsapp-port>). See SSO_PLAN.md.
MEENITS_CLIENT_ID=
MEENITS_CLIENT_SECRET=
MEENITS_REDIRECT_URI=https://trac.meenits.app/auth/meenits/callback
MEENITS_AUTHORIZE_URL=https://app.meenits.app/oauth/authorize
MEENITS_TOKEN_URL=https://app.meenits.app/oauth/token
MEENITS_USERINFO_URL=https://app.meenits.app/api/user
MEENITS_ORGS_URL=https://app.meenits.app/api/user/organizations
